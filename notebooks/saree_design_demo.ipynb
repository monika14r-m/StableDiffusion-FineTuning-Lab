# Saree Design Transfer Demo
# --------------------------

from diffusers import StableDiffusionPipeline
from diffusers import ControlNetModel
import torch
from PIL import Image

# Load base model + ControlNet
base_model = "runwayml/stable-diffusion-v1-5"
controlnet = ControlNetModel.from_pretrained("lllyasviel/sd-controlnet-seg")

pipe = StableDiffusionPipeline.from_pretrained(
    base_model,
    controlnet=controlnet,
    torch_dtype=torch.float16
).to("cuda")

# Load saree base image + mask
saree_img = Image.open("data/sarees/base1.png")
mask_img = Image.open("data/sarees/masks/base1_mask.png")

# Prompt with design token
prompt = "studio shot of silk saree with intricate peacock embroidery"

# Generate
result = pipe(prompt=prompt, image=saree_img, mask_image=mask_img).images[0]
result.save("outputs/saree_design_demo.png")
